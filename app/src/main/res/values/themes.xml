<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.MyThoughts" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <item name="colorPrimary">@color/brand_red</item>
        <item name="colorPrimaryVariant">#6B0000</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/brand_dark</item>
        <item name="colorSecondaryVariant">@color/brand_dark</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="android:statusBarColor">@color/brand_red</item>
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>

    <style name="Theme.MyThoughts.Splash" parent="Theme.MyThoughts">
        <item name="android:windowBackground">@color/white</item>
        <item name="android:statusBarColor">@color/white</item>
        <item name="android:navigationBarColor">@color/white</item>
    </style>

</resources>
